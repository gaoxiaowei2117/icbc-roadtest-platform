# 部署到 /opt/icbc-platform/.env 后填实际值
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_DB=icbc_platform
POSTGRES_USER=icbc
POSTGRES_PASSWORD=填-init-db-时设的密码

JWT_SECRET=$(python3 -c "import secrets; print(secrets.token_urlsafe(32))")
ENCRYPTION_KEY=$(python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
WORKER_API_KEY=$(python3 -c "import secrets; print(secrets.token_urlsafe(24))")

API_V1_PREFIX=/api
APP_BASE_URL=https://gogoxoxo.duckdns.org:9443
FRONTEND_BASE_PATH=/booking
CORS_ORIGINS=https://gogoxoxo.duckdns.org:9443

BOOTSTRAP_ADMIN_EMAIL=你的admin邮箱
BOOTSTRAP_ADMIN_PASSWORD=一个强密码
