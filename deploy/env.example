# 部署到 /opt/icbc-platform/.env 后填实际值
# ===== Postgres（init-db.sh 步骤里设的） =====
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_DB=icbc_platform
POSTGRES_USER=icbc
POSTGRES_PASSWORD=填-init-db-时设的密码

# ===== 安全密钥（占位值，跑下面命令生成真值替换） =====
# JWT_SECRET=$(python3 -c "import secrets; print(secrets.token_urlsafe(32))")
JWT_SECRET=change-me-jwt-secret
# WORKER_API_KEY=$(python3 -c "import secrets; print(secrets.token_urlsafe(24))")
WORKER_API_KEY=change-me-worker-key

# 凭据加密：云端只放【公钥】（只能加密）。私钥放本地 worker 的 .env，云端永远不要有。
# 生成密钥对（在本地 worker 机器上跑，把公钥贴到这里、私钥贴到 worker/.env）：
#   python -c "from nacl.public import PrivateKey; from nacl.encoding import Base64Encoder; \
#     sk=PrivateKey.generate(); \
#     print('SECRET_PRIVATE_KEY=', sk.encode(Base64Encoder).decode()); \
#     print('SECRET_PUBLIC_KEY=', sk.public_key.encode(Base64Encoder).decode())"
SECRET_PUBLIC_KEY=change-me-public-key

# ===== 应用 =====
API_V1_PREFIX=/api
APP_BASE_URL=https://gogoxoxo.duckdns.org:9443
FRONTEND_BASE_PATH=/booking
CORS_ORIGINS=https://gogoxoxo.duckdns.org:9443

# ===== 启动时自动创建的 admin 账号 =====
BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_ADMIN_PASSWORD=change-me-admin-password
