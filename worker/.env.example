# ===== 云端 API =====
API_BASE_URL=https://gogoxoxo.duckdns.org:9443
WORKER_API_KEY=change-me-worker-key

# ===== 凭据解密私钥（与云端 SECRET_PUBLIC_KEY 成对，只放本地）=====
# 生成：python -c "from nacl.public import PrivateKey; from nacl.encoding import Base64Encoder; \
#   sk=PrivateKey.generate(); \
#   print('SECRET_PRIVATE_KEY=', sk.encode(Base64Encoder).decode()); \
#   print('（公钥填到云端）SECRET_PUBLIC_KEY=', sk.public_key.encode(Base64Encoder).decode())"
SECRET_PRIVATE_KEY=change-me-private-key

# ===== worker 行为 =====
POLL_INTERVAL_SECONDS=5
MAX_CONCURRENT=3
HEADLESS=true
LOG_LEVEL=INFO
LOG_FILE=worker.log

# ===== road.py 抢号 =====
# 实际配置在 worker/config.yml（复制 config.example.yml 填真值，被 gitignore）
ROAD_CONFIG_PATH=./config.yml
BOOKING_TIMEOUT_SECONDS=600   # 须 < backend RUNNING_TIMEOUT_MINUTES(900s)
BOOKING_POLL_SECONDS=30

# ===== 系统级 Gmail（收 ICBC OTP，所有用户共享）=====
# 用 Gmail 应用专用密码（非登录密码）：Google 账号 → 安全 → 两步验证 → 应用专用密码
GMAIL_EMAIL=system-icbc@gmail.com
GMAIL_APP_PASSWORD=your 16char app password
