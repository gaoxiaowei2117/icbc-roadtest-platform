# ===== Postgres =====
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_DB=icbc_platform
POSTGRES_USER=icbc
POSTGRES_PASSWORD=change-me-strong-password

# ===== 安全 =====
# 用 `python -c "import secrets; print(secrets.token_urlsafe(32))"` 生成
JWT_SECRET=change-me-jwt-secret
# 用 `python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"` 生成
ENCRYPTION_KEY=change-me-fernet-key
# Worker 调用后端 admin 接口的共享密钥
WORKER_API_KEY=change-me-worker-key

# ===== 应用 =====
API_V1_PREFIX=/api
APP_BASE_URL=https://gogoxoxo.duckdns.org:9443
FRONTEND_BASE_PATH=/booking
CORS_ORIGINS=https://gogoxoxo.duckdns.org:9443

# ===== 启动时自动创建的 admin 账号（如果邮箱不存在） =====
BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_ADMIN_PASSWORD=change-me-admin-password
