# ===== Postgres =====
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_DB=icbc_platform
POSTGRES_USER=icbc
POSTGRES_PASSWORD=change-me-strong-password

# ===== 安全 =====
# 用 `python -c "import secrets; print(secrets.token_urlsafe(32))"` 生成
JWT_SECRET=change-me-jwt-secret
# Worker 调用后端 admin 接口的共享密钥
WORKER_API_KEY=change-me-worker-key
# 凭据加密：后端只放公钥，私钥只放 worker/.env
# 生成：python -c "from nacl.public import PrivateKey; from nacl.encoding import Base64Encoder; sk=PrivateKey.generate(); print('SECRET_PRIVATE_KEY=', sk.encode(Base64Encoder).decode()); print('SECRET_PUBLIC_KEY=', sk.public_key.encode(Base64Encoder).decode())"
SECRET_PUBLIC_KEY=change-me-public-key

# ===== 邮箱验证 SMTP =====
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=system-icbc@gmail.com
SMTP_PASSWORD=your 16char app password
SMTP_FROM=system-icbc@gmail.com

# ===== 应用 =====
API_V1_PREFIX=/api
APP_BASE_URL=https://gogoxoxo.duckdns.org:9443
FRONTEND_BASE_PATH=/booking
CORS_ORIGINS=https://gogoxoxo.duckdns.org:9443

# ===== 启动时自动创建的 admin 账号（如果邮箱不存在） =====
BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_ADMIN_PASSWORD=change-me-admin-password
